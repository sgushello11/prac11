<Window x:Class="DocumentFlowApp.DocumentEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование документа" Height="500" Width="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Тип:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbDocType" Grid.Row="0" Grid.Column="1" Margin="5">
            <ComboBoxItem Content="Входящий"/>
            <ComboBoxItem Content="Исходящий"/>
        </ComboBox>

        <TextBlock Text="Номер:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="txtNumber" Grid.Row="1" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Дата:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <DatePicker x:Name="dpDate" Grid.Row="2" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Время:" Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="txtTime" Grid.Row="3" Grid.Column="1" Margin="5" Text="00:00"/>

        <TextBlock Text="Контрагент:" Grid.Row="4" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="txtCounterparty" Grid.Row="4" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Сотрудник:" Grid.Row="5" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbEmployee" Grid.Row="5" Grid.Column="1" Margin="5"
                  DisplayMemberPath="FullName" SelectedValuePath="Id"/>

        <TextBlock Text="Тема:" Grid.Row="6" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="txtSubject" Grid.Row="6" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Содержание:" Grid.Row="7" Grid.Column="0" Margin="5" VerticalAlignment="Top"/>
        <TextBox x:Name="txtContent" Grid.Row="7" Grid.Column="1" Margin="5" Height="100" 
                 TextWrapping="Wrap" AcceptsReturn="True"/>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="Сохранить" Width="90" Height="30" Margin="5" Click="btnSave_Click" Background="Green" Foreground="White"/>
            <Button Content="Отмена" Width="90" Height="30" Margin="5" Click="btnCancel_Click" Background="Gray" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>