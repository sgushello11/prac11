<Window x:Class="DocumentFlowApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учёт входящих/исходящих документов" Height="500" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Информация о пользователе -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Пользователь: " FontWeight="Bold"/>
            <TextBlock x:Name="tbUser" Margin="5,0,20,0"/>
            <TextBlock Text="Роль: " FontWeight="Bold"/>
            <TextBlock x:Name="tbRole" Foreground="Blue" FontWeight="Bold"/>
        </StackPanel>

        <!-- Поиск -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Номер документа:" VerticalAlignment="Center"/>
            <TextBox x:Name="txtSearchNumber" Width="150" Margin="10,0" Height="25"/>
            <Button x:Name="btnSearch" Content="Найти" Click="btnSearch_Click" Width="70" Height="25" Margin="0,0,5,0"/>
            <Button x:Name="btnClear" Content="Сброс" Click="btnClear_Click" Width="70" Height="25" Margin="0,0,5,0"/>
            <Button x:Name="btnStats" Content="Статистика" Click="btnStats_Click" Width="80" Height="25"/>
        </StackPanel>

        <!-- Таблица документов -->
        <DataGrid x:Name="dgDocuments" Grid.Row="2" AutoGenerateColumns="True" SelectionMode="Single"
                  AlternatingRowBackground="LightGray" GridLinesVisibility="Horizontal"/>

        <!-- Кнопки CRUD -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="btnAdd" Content="Добавить" Width="90" Height="30" Margin="5" Click="btnAdd_Click" Background="Green" Foreground="White"/>
            <Button x:Name="btnEdit" Content="Изменить" Width="90" Height="30" Margin="5" Click="btnEdit_Click" Background="Orange" Foreground="White"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="90" Height="30" Margin="5" Click="btnDelete_Click" Background="Red" Foreground="White"/>
            <Button x:Name="btnRefresh" Content="Обновить" Width="90" Height="30" Margin="5" Click="btnRefresh_Click" Background="Blue" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>